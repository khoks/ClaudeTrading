# Copy to .env and fill in. .env is gitignored.
#
# How to get ALPACA_KEY and ALPACA_SECRET:
#   1. Sign up free at https://alpaca.markets/signup (paper trading needs no funding).
#   2. Open https://app.alpaca.markets/paper/dashboard/overview
#   3. Find the "API Keys" panel on the right side of the dashboard.
#   4. Click "Regenerate" — the SECRET is shown ONCE; paste it below immediately.
#      (If you lose it, just regenerate again. The previous secret stops working.)
#   5. Make sure the Endpoint shown there matches ALPACA_BASE below (paper-only).
#
# README.md has a fuller walkthrough under "Generating Alpaca paper credentials".

ALPACA_KEY=
ALPACA_SECRET=
ALPACA_BASE=https://paper-api.alpaca.markets/v2
ALPACA_DATA_BASE=https://data.alpaca.markets/v2

# ---- Notifications (optional) ---------------------------------------------
# If set, master_trading_v2 sends a Telegram message whenever a tick places
# orders, plus anomaly alerts and the daily report summary. See
# docs/SETUP_TELEGRAM.md for the 5-minute bot creation walkthrough.
#
# Leave both blank to disable notifications (the lib fails-soft).

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Channel: "telegram" (default), "sms_textbelt" (testing only — limited free
# quota, US numbers often blocked), or "none" to silence all notifications.
NOTIFY_DEFAULT_CHANNEL=telegram

# Optional: paid TextBelt API key for production SMS instead of the free tier.
# Get one at https://textbelt.com/. With a key, paid SMS works reliably.
# TEXTBELT_KEY=
