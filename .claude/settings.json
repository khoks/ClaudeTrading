{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(bash:*)",
      "Bash(date:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(printf:*)",
      "Bash(echo:*)",
      "Bash(source:*)",
      "Bash(test:*)",
      "Bash([:*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "mcp__scheduled-tasks__list_scheduled_tasks"
    ],
    "ask": [
      "Bash(gh repo create:*)",
      "Bash(gh repo delete:*)",
      "mcp__scheduled-tasks__create_scheduled_task",
      "mcp__scheduled-tasks__update_scheduled_task"
    ]
  }
}
